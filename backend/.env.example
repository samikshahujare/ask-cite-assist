# === Zero-cost recommended setup ===
# 1) Create a free OpenRouter key and paste it below.
# 2) Keep EMBEDDING_PROVIDER=local so embeddings run free on your CPU.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# === Embeddings ===
# "openai" works with OpenAI only (OpenRouter has NO embeddings endpoint).
# "local" uses sentence-transformers (free, CPU, 384 dims). Use this with OpenRouter.
EMBEDDING_PROVIDER=local
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional — enables Researcher web search fallback (https://tavily.com, free tier)
TAVILY_API_KEY=

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# Storage paths (relative to backend/)
DATA_DIR=data

# CORS — comma-separated list of allowed local/custom frontend origins.
# Lovable preview URLs are allowed by ALLOWED_ORIGIN_REGEX below.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
ALLOWED_ORIGIN_REGEX=https://.*\.(lovable\.app|lovableproject\.com)$