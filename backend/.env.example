# === LLM (chat) ===
# Works with OpenAI OR any OpenAI-compatible provider (OpenRouter, Together, Groq, etc.)
#
# --- OpenAI (default) ---
# OPENAI_API_KEY=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
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_CHAT_MODEL=gpt-4o-mini
#
# --- OpenRouter ---
# OPENAI_API_KEY=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_CHAT_MODEL=openai/gpt-4o-mini    # or anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-70b-instruct, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini

# === Embeddings ===
# "openai" works with OpenAI only (OpenRouter has NO embeddings endpoint).
# "local" uses sentence-transformers (free, CPU, 384 dims). Use this with OpenRouter.
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional — enables Researcher web search fallback (https://tavily.com, free tier)
TAVILY_API_KEY=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

# RAG
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# Storage paths (relative to backend/)
DATA_DIR=data

# CORS — comma-separated list of allowed local/custom frontend origins.
# Lovable preview URLs are allowed by ALLOWED_ORIGIN_REGEX below.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080
ALLOWED_ORIGIN_REGEX=https://.*\.lovable\.app